{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adftrendytech02"
		},
		"ADLS Gen2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ADLS Gen2'"
		},
		"spotify_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'spotify_db'"
		},
		"ADLS Gen2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsspotify01.dfs.core.windows.net"
		},
		"spotify_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "trendytechhospital.database.windows.net"
		},
		"spotify_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "spotify_db"
		},
		"spotify_db_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adftrendytech02_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ADLS Gen2_accountKey": {
						"value": "[parameters('ADLS Gen2_accountKey')]"
					},
					"spotify_db_password": {
						"value": "[parameters('spotify_db_password')]"
					},
					"ADLS Gen2_properties_typeProperties_url": {
						"value": "[parameters('ADLS Gen2_properties_typeProperties_url')]"
					},
					"spotify_db_properties_typeProperties_server": {
						"value": "[parameters('spotify_db_properties_typeProperties_server')]"
					},
					"spotify_db_properties_typeProperties_database": {
						"value": "[parameters('spotify_db_properties_typeProperties_database')]"
					},
					"spotify_db_properties_typeProperties_userName": {
						"value": "[parameters('spotify_db_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}